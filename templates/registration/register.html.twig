{% extends 'template.html.twig' %}

{% block title %}S'inscrire - CVitae{% endblock %}

{% block body %}
<div class="flex items-center justify-center min-h-[80vh] py-10">
    <div class="w-full max-w-4xl rounded-sm border border-stroke bg-white shadow-default dark:border-strokedark dark:bg-boxdark">
        <div class="border-b border-stroke py-4 px-6.5 dark:border-strokedark text-center">
            <h3 class="font-semibold text-2xl text-black dark:text-white">
                Créer un compte CVitae
            </h3>
        </div>
        <div class="p-6.5">
            {{ form_start(registrationForm, {'attr': {'class': 'flex flex-col gap-6'}}) }}
                {{ form_errors(registrationForm) }}

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <!-- Left Column: Personal Info -->
                    <div class="flex flex-col gap-6">
                        <div class="mb-2 text-center">
                             <h4 class="font-semibold text-lg mb-4 text-black dark:text-white border-b pb-2 inline-block px-4">Informations Personnelles</h4>
                        </div>
                        
                        <div class="grid grid-cols-2 gap-4">
                            <div class="text-center">
                                {{ form_label(registrationForm.nom, 'Nom', {'label_attr': {'class': 'mb-2.5 block font-medium text-black dark:text-white'}}) }}
                                {{ form_widget(registrationForm.nom, {'attr': {'class': 'w-full rounded-lg border border-stroke bg-transparent py-4 text-center outline-none focus:border-primary focus-visible:shadow-none dark:border-form-strokedark dark:bg-form-input dark:focus:border-primary', 'placeholder': 'Votre nom'}}) }}
                                {{ form_errors(registrationForm.nom) }}
                            </div>
                            <div class="text-center">
                                {{ form_label(registrationForm.prenom, 'Prénom', {'label_attr': {'class': 'mb-2.5 block font-medium text-black dark:text-white'}}) }}
                                {{ form_widget(registrationForm.prenom, {'attr': {'class': 'w-full rounded-lg border border-stroke bg-transparent py-4 text-center outline-none focus:border-primary focus-visible:shadow-none dark:border-form-strokedark dark:bg-form-input dark:focus:border-primary', 'placeholder': 'Votre prénom'}}) }}
                                {{ form_errors(registrationForm.prenom) }}
                            </div>
                        </div>

                         <div class="text-center">
                            {{ form_label(registrationForm.date_de_naissance, 'Date de naissance', {'label_attr': {'class': 'mb-2.5 block font-medium text-black dark:text-white'}}) }}
                            {{ form_widget(registrationForm.date_de_naissance, {'attr': {'class': 'w-full rounded-lg border border-stroke bg-transparent py-4 text-center outline-none focus:border-primary focus-visible:shadow-none dark:border-form-strokedark dark:bg-form-input dark:focus:border-primary'}}) }}
                            {{ form_errors(registrationForm.date_de_naissance) }}
                        </div>

                        <div class="text-center">
                            {{ form_label(registrationForm.adresse, 'Adresse', {'label_attr': {'class': 'mb-2.5 block font-medium text-black dark:text-white'}}) }}
                            {{ form_widget(registrationForm.adresse, {'attr': {'class': 'w-full rounded-lg border border-stroke bg-transparent py-4 text-center outline-none focus:border-primary focus-visible:shadow-none dark:border-form-strokedark dark:bg-form-input dark:focus:border-primary', 'placeholder': 'Votre adresse complète'}}) }}
                            {{ form_errors(registrationForm.adresse) }}
                        </div>
                    </div>

                    <!-- Right Column: Account Info -->
                    <div class="flex flex-col gap-6">
                        <div class="mb-2 text-center">
                            <h4 class="font-semibold text-lg mb-4 text-black dark:text-white border-b pb-2 inline-block px-4">Identifiants & Contact</h4>
                        </div>

                        <div class="text-center">
                            {{ form_label(registrationForm.email, 'Email', {'label_attr': {'class': 'mb-2.5 block font-medium text-black dark:text-white'}}) }}
                            {{ form_widget(registrationForm.email, {'attr': {'class': 'w-full rounded-lg border border-stroke bg-transparent py-4 text-center outline-none focus:border-primary focus-visible:shadow-none dark:border-form-strokedark dark:bg-form-input dark:focus:border-primary', 'placeholder': 'exemple@email.com'}}) }}
                            {{ form_errors(registrationForm.email) }}
                        </div>

                        <div class="text-center">
                            {{ form_label(registrationForm.plainPassword, 'Mot de passe', {'label_attr': {'class': 'mb-2.5 block font-medium text-black dark:text-white'}}) }}
                            {{ form_widget(registrationForm.plainPassword, {'attr': {'class': 'w-full rounded-lg border border-stroke bg-transparent py-4 text-center outline-none focus:border-primary focus-visible:shadow-none dark:border-form-strokedark dark:bg-form-input dark:focus:border-primary', 'placeholder': 'Choisir un mot de passe'}}) }}
                            {{ form_errors(registrationForm.plainPassword) }}
                        </div>

                        <div class="text-center">
                            {{ form_label(registrationForm.telephone, 'Téléphone', {'label_attr': {'class': 'mb-2.5 block font-medium text-black dark:text-white'}}) }}
                            {{ form_widget(registrationForm.telephone, {'attr': {'class': 'w-full rounded-lg border border-stroke bg-transparent py-4 text-center outline-none focus:border-primary focus-visible:shadow-none dark:border-form-strokedark dark:bg-form-input dark:focus:border-primary', 'placeholder': '06 12 34 56 78'}}) }}
                            {{ form_errors(registrationForm.telephone) }}
                        </div>
                    </div>
                </div>

                <div class="mt-6">
                    <button class="w-full cursor-pointer rounded-lg border border-primary bg-primary p-4 text-white transition hover:bg-opacity-90 font-medium text-lg" type="submit">
                        Créer mon compte
                    </button>
                </div>

                <div class="mt-2 text-center">
                    <p class="font-medium">
                        Vous avez déjà un compte ? 
                        <a href="{{ path('app_login') }}" class="text-primary hover:underline">Connectez-vous</a>
                    </p>
                </div>
            {{ form_end(registrationForm) }}
        </div>
    </div>
</div>
{% endblock %}
