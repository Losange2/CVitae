<form method="post" action="{{ path('app_cv_delete', {'id': cv.id}) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer ce CV ? Cette action est irréversible.');" class="inline-block">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ cv.id) }}">
    <button class="{{ button_class|default('btn') }}">
        {{ button_label|default('Supprimer')|raw }}
    </button>
</form>
